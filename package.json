{
  "name": "@lemondouble/lemon-auth",
  "version": "0.3.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/LemonDouble/lemon-auth"
  },
  "description": "*.lemondouble.com 서비스를 위한 인증 라이브러리",
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./proxy": {
      "types": "./dist/proxy/index.d.ts",
      "import": "./dist/proxy/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "packageManager": "pnpm@10.25.0",
  "peerDependencies": {
    "next": ">=16.0.0",
    "react": ">=19.0.0"
  },
  "dependencies": {
    "jose": "^6.2.2"
  },
  "keywords": [
    "auth",
    "lemondouble",
    "next.js",
    "jwt"
  ],
  "author": "lemondouble",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
